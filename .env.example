# Contact Sheet — environment variables
# Copy to .env.local (gitignored) and fill in real values.

# ── Anthropic (server-side shared key for free + pro tiers) ─────────
# A second, separate key from your personal dev key. Used by the
# /api/cull, /api/deep-review, /api/compare routes for users on the
# free or pro tier. BYOK users send their own key client-side and
# this var is not consulted for them.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Clerk (auth) ────────────────────────────────────────────────────
# Create an application at https://dashboard.clerk.com/
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Stripe (billing) ────────────────────────────────────────────────
# Stay in Test mode until the app is ready to accept real cards.
# Create a Product → recurring price ($5/mo) and copy the price ID.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
# Generated later when the webhook endpoint is created against Vercel.
STRIPE_WEBHOOK_SECRET=
